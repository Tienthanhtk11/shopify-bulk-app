# Copy thành .env cho local / docker-compose.

# Postgres — bắt buộc cho docker-compose (service postgres + biến thay thế ${POSTGRES_PASSWORD})
POSTGRES_PASSWORD=đổi_thành_mật_khẩu_mạnh

# URL cho Prisma / shopify app dev chạy trên máy host (cổng 5433 map từ container)
DATABASE_URL=postgresql://subbulk:đổi_thành_mật_khẩu_mạnh@127.0.0.1:5433/subbulk?schema=public

# Trong container `subbulk`, docker-compose ghi đè DATABASE_URL trỏ tới host `postgres:5432`.

# Shopify (bắt buộc khi chạy app)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,read_products,write_purchase_options,read_purchase_options,read_own_subscription_contracts,write_own_subscription_contracts,read_customers,read_orders,write_app_proxy
SHOPIFY_APP_URL=

# Tuỳ chọn
# SHOP_CUSTOM_DOMAIN=
