# Copy thành .env cho local / docker-compose. Trên VM Docker chỉ cần truyền -e hoặc env_file.

# Prisma (bắt buộc) — đường dẫn tương đối theo thư mục chứa schema.prisma
DATABASE_URL=file:dev.sqlite

# Shopify (bắt buộc khi chạy app)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=
SHOPIFY_APP_URL=

# Tuỳ chọn
# SHOP_CUSTOM_DOMAIN=
