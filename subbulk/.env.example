# Copy thành .env cho local / docker-compose.

# Postgres — bắt buộc cho docker-compose (service postgres + biến thay thế ${POSTGRES_PASSWORD})
POSTGRES_PASSWORD=đổi_thành_mật_khẩu_mạnh

# URL cho Prisma / shopify app dev chạy trên máy host (cổng 5433 map từ container)
DATABASE_URL=postgresql://subbulk:đổi_thành_mật_khẩu_mạnh@127.0.0.1:5433/subbulk?schema=public

# Trong container `subbulk`, docker-compose ghi đè DATABASE_URL trỏ tới host `postgres:5432`.

# Shopify (bắt buộc khi chạy app)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,read_products,read_themes,write_purchase_options,read_purchase_options,read_own_subscription_contracts,read_customers,read_orders,write_app_proxy,write_discounts,read_discounts
SHOPIFY_APP_URL=

# Tuỳ chọn
# SHOP_CUSTOM_DOMAIN=

# Merchant billing mapping voi ten / GID plan trong Partner Dashboard
PARTNER_PLAN_FREE_NAMES=Free
PARTNER_PLAN_FREE_GIDS=
PARTNER_PLAN_GROWTH_NAMES=Growth
PARTNER_PLAN_GROWTH_GIDS=
PARTNER_PLAN_SCALE_NAMES=Scale
PARTNER_PLAN_SCALE_GIDS=

# Secret va cadence cho job runner xu ly merchant data deletion queue
JOB_RUNNER_SECRET=doi_thanh_secret_ngau_nhien_dai
DELETION_JOB_INTERVAL_SECONDS=300

# Internal admin portal on admin-app.thanhpt.online
INTERNAL_ADMIN_SESSION_SECRET=doi_thanh_secret_cookie_rieng
# Bootstrap one or more portal admins into DB on first run only.
INTERNAL_ADMIN_PORTAL_ACCOUNTS=admin@thanhpt.online:doi_mat_khau_manh:ThanhPT Admin

# Optional: direct merchant-facing link to Shopify-hosted managed pricing page.
SHOPIFY_MANAGED_PRICING_APP_HANDLE=
# Optional: set truthy only after Partner Dashboard pricing content is fully published.
# SHOPIFY_MANAGED_PRICING_READY=false

# Optional: enable a Shopify Billing API test-charge fallback while managed pricing is still unpublished.
# Keep this disabled in production once managed pricing is live.
# SHOPIFY_BILLING_TEST_FALLBACK_ENABLED=false
